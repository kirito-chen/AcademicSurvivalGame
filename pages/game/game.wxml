<!-- 学术 Roguelike —— 游戏主页面 -->
<view class="game-page">

  <!-- ===== 顶部状态栏 ===== -->
  <view class="top-bar">
    <view class="level-info">
      <view class="level-header">
        <text class="level-num">第 {{roundNumber}}/{{totalRounds}} 关</text>
        <text class="level-boss" wx:if="{{isBoss}}">⚡BOSS</text>
      </view>
      <text class="level-name">{{levelName}}</text>
      <view class="level-target">
        <text class="target-label">目标产出:</text>
        <text class="target-value">{{scoreTarget}}</text>
      </view>
    </view>

    <view class="resource-row">
      <view class="resource-item">
        <text class="res-icon">⚡</text>
        <view class="res-bar-wrap">
          <view class="res-bar-fill energy" style="width: {{energy}}%"></view>
        </view>
        <text class="res-text">{{energy}}</text>
      </view>
      <view class="resource-item">
        <text class="res-icon">💰</text>
        <view class="res-bar-wrap">
          <view class="res-bar-fill funding" style="width: {{funding / 100}}%"></view>
        </view>
        <text class="res-text">¥{{funding}}</text>
      </view>
    </view>
  </view>

  <!-- ===== Boss 效果横幅 ===== -->
  <view class="boss-banner" wx:if="{{bossEffect}}">
    <text class="boss-icon">⚠️</text>
    <text class="boss-text">{{bossEffect.description}}</text>
  </view>

  <!-- ===== 技能槽位区 ===== -->
  <view class="skill-slots-area">
    <view class="skill-slots-row">
      <block wx:for="{{maxSkillSlots}}" wx:key="index">
        <skill-slot
          skill="{{skills[index] || null}}"
          index="{{index}}"
        />
      </block>
    </view>
  </view>

  <!-- ===== 主区域: 出牌区 ===== -->
  <view class="main-area">
    <view class="played-zone">
      <text class="zone-label" wx:if="{{playedCards.length === 0}}">点击手牌选中，再按「出牌」打出</text>
      <scroll-view class="played-scroll" scroll-x wx:if="{{playedCards.length > 0}}">
        <view class="played-row">
          <game-card
            wx:for="{{playedCards}}"
            wx:key="index"
            card="{{item}}"
            cardType="research"
            compact="{{true}}"
            showDetail="{{false}}"
          />
        </view>
      </scroll-view>
      <text class="play-count" wx:if="{{playedCards.length > 0}}">
        已打出 {{playedCards.length}}/{{maxPlays}} 张
      </text>
    </view>
  </view>

  <!-- ===== 手牌区 ===== -->
  <view class="hand-area">
    <view class="hand-header">
      <text class="hand-label">📋 手牌 ({{handSize}}/{{maxHandSize}})</text>
    </view>
    <scroll-view class="hand-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="hand-row">
        <view
          wx:for="{{hand}}"
          wx:key="index"
          data-index="{{index}}"
          class="hand-card-wrapper {{selectedCardIndex === index ? 'card-selected' : ''}}"
          bindtap="onSelectCard"
        >
          <game-card
            card="{{item}}"
            cardType="research"
            selected="{{selectedCardIndex === index}}"
            compact="{{true}}"
          />
        </view>
        <view class="hand-empty" wx:if="{{hand.length === 0}}">
          <text>牌组已空，结算后重新洗牌</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ===== 底部操作栏 ===== -->
  <view class="action-bar">
    <pixel-button
      theme="primary"
      size="small"
      disabled="{{selectedCardIndex < 0 || inShop || gameOver}}"
      bindtap="onPlayCard"
    >出牌</pixel-button>

    <pixel-button
      theme="secondary"
      size="small"
      disabled="{{inShop || gameOver}}"
      bindtap="onFinishRound"
    >结算回合</pixel-button>

    <pixel-button
      theme="ghost"
      size="small"
      disabled="{{inShop || gameOver}}"
      bindtap="onSkipRound"
    >跳过</pixel-button>

    <pixel-button
      theme="ghost"
      size="small"
      bindtap="onSave"
    >存档</pixel-button>
  </view>

  <!-- ===== Toast ===== -->
  <view class="toast" wx:if="{{showToast}}">
    <text>{{toastText}}</text>
  </view>

  <!-- ===== 游戏结束遮罩 ===== -->
  <view class="game-over-overlay" wx:if="{{gameOver}}">
    <view class="game-over-card">
      <text class="game-over-text">游戏结束</text>
      <text class="game-over-sub">正在前往结局页面...</text>
    </view>
  </view>

</view>
