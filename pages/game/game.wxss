/**
 * 学术 Roguelike —— 游戏主页面样式
 * 单屏布局: 100vh flex column, overflow:hidden
 */

.game-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: #1a1a2e;
  color: #eeeeb8;
}

/* ===== 顶部状态栏 ===== */
.top-bar {
  padding: 8rpx 20rpx;
  background: #16213e;
  border-bottom: 4rpx solid #e94560;
  flex-shrink: 0;
}

.level-info {
  display: flex;
  flex-direction: column;
}

.level-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.level-num {
  font-size: 22rpx;
  font-weight: bold;
  color: #eeeeb8;
}

.level-boss {
  font-size: 22rpx;
  color: #e94560;
  font-weight: bold;
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.level-name {
  font-size: 20rpx;
  color: #888;
  margin: 2rpx 0;
}

.level-target {
  display: flex;
  gap: 8rpx;
  align-items: baseline;
}

.target-label {
  font-size: 20rpx;
  color: #888;
}

.target-value {
  font-size: 28rpx;
  color: #f0a500;
  font-weight: bold;
}

/* 资源行 */
.resource-row {
  display: flex;
  gap: 16rpx;
  margin-top: 4rpx;
}

.resource-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.res-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.res-bar-wrap {
  flex: 1;
  height: 12rpx;
  background: #0f0f23;
  border: 2rpx solid #333;
  overflow: hidden;
}

.res-bar-fill {
  height: 100%;
  transition: width 0.3s ease;
}

.res-bar-fill.energy { background: #00b4d8; box-shadow: 0 0 6rpx #00b4d8; }
.res-bar-fill.funding { background: #f0a500; box-shadow: 0 0 6rpx #f0a500; }

.res-text {
  font-size: 18rpx;
  color: #eeeeb8;
  font-weight: bold;
  min-width: 50rpx;
  text-align: right;
}

/* ===== Boss 横幅 ===== */
.boss-banner {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(233, 69, 96, 0.2);
  border-bottom: 2rpx solid #e94560;
  flex-shrink: 0;
}
.boss-icon { font-size: 24rpx; }
.boss-text { font-size: 20rpx; color: #e94560; flex: 1; }

/* ===== 技能槽 ===== */
.skill-slots-area {
  padding: 6rpx 20rpx;
  flex-shrink: 0;
  border-bottom: 2rpx solid #333;
  max-height: 130rpx;
  overflow-y: auto;
}
.skill-slots-row {
  display: flex;
  gap: 8rpx;
}

/* ===== 回合状态 ===== */
.round-status {
  display: flex; gap: 16rpx; padding: 8rpx 16rpx; flex-wrap: wrap; justify-content: center;
}
.status-item { font-size: 20rpx; color: #eeeeb8; font-weight: bold; }

/* ===== 主区域 ===== */
.main-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  min-height: 80rpx;
  overflow: visible;
}

.played-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}
.zone-label { font-size: 24rpx; color: #555; text-align: center; }
.played-scroll { width: 100%; white-space: nowrap; }
.played-row { display: inline-flex; gap: 12rpx; padding: 8rpx; justify-content: center; }
.play-count { font-size: 20rpx; color: #888; margin-top: 8rpx; }
.play-hand-type { font-size: 24rpx; color: #f0a500; font-weight: bold; margin-top: 6rpx; }
.play-chips { font-size: 22rpx; color: #00b4d8; font-weight: bold; margin-top: 4rpx; }
.play-boss-warn { font-size: 18rpx; color: #e94560; margin-top: 4rpx; text-align: center; }

.play-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

/* ===== 手牌区 ===== */
.hand-area {
  padding: 12rpx 20rpx 10rpx;
  background: #16213e;
  border-top: 4rpx solid #333;
  flex-shrink: 0;
  min-height: 150rpx;
}
.hand-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6rpx; }
.hand-label { font-size: 20rpx; color: #888; }
.hand-hint { font-size: 18rpx; color: #f0a500; font-weight: bold; }

.hand-scroll { width: 100%; white-space: nowrap; }
.hand-row { display: inline-flex; gap: 10rpx; padding: 80rpx 0 8rpx; align-items: flex-end; }

.hand-card-wrapper { position: relative; bottom: 0; transition: bottom 0.12s ease; }
.hand-card-wrapper.card-picked { bottom: 75rpx; z-index: 10; filter: brightness(1.15); }

.hand-hint { font-size: 18rpx; color: #f0a500; font-weight: bold; }

/* 选中预览 */
.select-preview {
  margin-top: 12rpx; padding: 8rpx 16rpx;
  background: rgba(240, 165, 0, 0.15); border: 2rpx solid #f0a500;
}
.preview-label { font-size: 20rpx; color: #eeeeb8; }
.preview-hand { font-size: 20rpx; color: #f0a500; font-weight: bold; }
.preview-hand.none { color: #888; }

.hand-empty {
  display: flex; align-items: center; justify-content: center;
  height: 130rpx; width: 300rpx;
}
.hand-empty text { font-size: 22rpx; color: #555; }

/* ===== 操作栏 ===== */
.action-bar {
  display: flex; justify-content: center; gap: 16rpx;
  padding: 10rpx 20rpx; background: #16213e;
  border-top: 4rpx solid #333; flex-shrink: 0;
}

/* ===== Toast ===== */
.toast {
  position: fixed; top: 200rpx; left: 50%; transform: translateX(-50%);
  background: rgba(0,0,0,0.85); color: #eeeeb8;
  padding: 16rpx 32rpx; font-size: 24rpx; font-weight: bold;
  border: 3rpx solid #e94560;
  box-shadow: 4rpx 4rpx 0 rgba(233,69,96,0.5);
  z-index: 100; animation: toastIn 0.3s ease;
}
@keyframes toastIn {
  from { opacity: 0; transform: translateX(-50%) translateY(20rpx); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

/* ===== 游戏结束遮罩 ===== */
.game-over-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.8);
  display: flex; align-items: center; justify-content: center; z-index: 200;
}
.game-over-card {
  display: flex; flex-direction: column; align-items: center; gap: 16rpx;
  padding: 48rpx; background: #16213e;
  border: 4rpx solid #e94560; box-shadow: 8rpx 8rpx 0 rgba(233,69,96,0.5);
}
.game-over-text { font-size: 40rpx; font-weight: bold; color: #e94560; }
.game-over-sub { font-size: 24rpx; color: #888; }

/* ===== 牌型参考面板 ===== */
.hand-ref-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 300;
  display: flex; align-items: center; justify-content: center;
}
.hand-ref-panel { width: 85vw; max-width: 520rpx; padding: 32rpx; }
.ref-title { font-size: 30rpx; font-weight: bold; color: #f0a500; display: block; text-align: center; margin-bottom: 20rpx; }
.ref-list { display: flex; flex-direction: column; gap: 10rpx; }
.ref-row { display: flex; align-items: center; gap: 12rpx; padding: 10rpx 12rpx; background: rgba(255,255,255,0.05); }
.ref-icon { font-size: 30rpx; flex-shrink: 0; }
.ref-info { display: flex; flex-direction: column; }
.ref-name { font-size: 22rpx; font-weight: bold; color: #eeeeb8; }
.ref-detail { font-size: 18rpx; color: #888; }
