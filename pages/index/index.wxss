/**
 * 学术 Roguelike —— 首页样式
 */

.index-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1a 100%);
}

.hero-section { text-align: center; margin-bottom: 36rpx; }

.logo-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; animation: float 3s ease-in-out infinite; }
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10rpx)} }

.logo-title { font-size: 48rpx; font-weight: bold; color: #eeeeb8; display: block; margin-bottom: 8rpx; }
.logo-subtitle { font-size: 24rpx; color: #888; letter-spacing: 4rpx; }

.meta-bar { display: flex; align-items: center; justify-content: center; gap: 8rpx; margin-top: 16rpx; }
.meta-icon { font-size: 28rpx; }
.meta-text { font-size: 22rpx; color: #f0a500; font-weight: bold; }

.tagline { margin-top: 20rpx; text-align: center; padding: 16rpx 24rpx; border-color: #f0a500; }
.tagline-text { font-size: 24rpx; color: #f0a500; display: block; }

/* 菜单 */
.menu-section { width: 100%; max-width: 500rpx; display: flex; flex-direction: column; gap: 20rpx; }
.menu-btn { display: flex; flex-direction: column; align-items: center; padding: 24rpx 32rpx; text-align: center; }
.menu-btn-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.menu-btn-text { font-size: 32rpx; font-weight: bold; letter-spacing: 6rpx; }
.menu-btn-hint { font-size: 20rpx; color: #888; margin-top: 4rpx; }

/* 选择面板 */
.overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 100; display: flex; align-items: center; justify-content: center; }
.panel { width: 85vw; max-width: 500rpx; padding: 32rpx; }

.panel-title { font-size: 36rpx; font-weight: bold; color: #eeeeb8; display: block; text-align: center; margin-bottom: 8rpx; }
.panel-subtitle { font-size: 22rpx; color: #888; display: block; text-align: center; margin-bottom: 24rpx; }

.panel-list { display: flex; flex-direction: column; gap: 12rpx; }
.panel-card { padding: 16rpx 20rpx; transition: all 0.1s; }
.panel-card:active { transform: scale(0.98); }
.card-selected { border-color: #2ecc71 !important; background: rgba(46,204,113,0.1); }
.card-locked { opacity: 0.5; }
.card-header { display: flex; align-items: center; gap: 10rpx; margin-bottom: 4rpx; }
.card-icon { font-size: 32rpx; }
.card-name { font-size: 28rpx; font-weight: bold; color: #eeeeb8; }
.lock-icon { font-size: 22rpx; color: #e94560; margin-left: auto; }
.card-desc { font-size: 22rpx; color: #888; line-height: 1.5; }

.panel-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 24rpx; padding-top: 16rpx; border-top: 2rpx dashed #333; }
.panel-tip { font-size: 22rpx; color: #f0a500; }

/* 关于 */
.about-panel { width: 100%; max-width: 500rpx; margin-top: 32rpx; padding: 24rpx; }
.about-title { font-size: 28rpx; color: #f0a500; display: block; margin-bottom: 16rpx; }
.about-content { display: flex; flex-direction: column; gap: 8rpx; }
.about-text { font-size: 24rpx; color: #888; line-height: 1.6; }

.footer { margin-top: auto; padding-top: 48rpx; }
.footer-text { font-size: 20rpx; color: #666; }
