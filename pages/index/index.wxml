<!-- 学术 Roguelike —— 首页 -->
<view class="index-page">

  <!-- 主视觉 -->
  <view class="hero-section">
    <view class="logo-area">
      <text class="logo-icon">🎓</text>
      <text class="logo-title pixel-text-glow">小丑牌-学术版</text>
      <text class="logo-subtitle">Academic Balatro-like Deck Builder</text>
    </view>

    <view class="meta-bar" wx:if="{{metaAP >= 0}}">
      <text class="meta-icon">{{metaIcon}}</text>
      <text class="meta-text">学术声望: {{metaAP}}</text>
    </view>

    <view class="tagline pixel-panel">
      <text class="tagline-text">"构建你的学术牌组，在科研的夹缝中求生。"</text>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="menu-section">
    <view class="menu-btn pixel-btn pixel-btn-large" bindtap="onNewGame">
      <text class="menu-btn-icon">🆕</text>
      <text class="menu-btn-text">新 的 Run</text>
      <text class="menu-btn-hint">选择学科，开始新一轮科研之旅</text>
    </view>

    <view class="menu-btn pixel-btn pixel-btn-large {{hasSave ? '' : 'pixel-btn-disabled'}}" bindtap="onContinue">
      <text class="menu-btn-icon">▶️</text>
      <text class="menu-btn-text">继 续 Run</text>
      <text class="menu-btn-hint" wx:if="{{hasSave}}">{{latestSaveLabel}}</text>
      <text class="menu-btn-hint" wx:else>暂无存档</text>
    </view>

    <view class="menu-btn pixel-btn pixel-btn-large" bindtap="onSaveManager">
      <text class="menu-btn-icon">💾</text>
      <text class="menu-btn-text">存 档 管 理</text>
    </view>

    <view class="menu-btn pixel-btn pixel-btn-large" bindtap="onToggleAbout">
      <text class="menu-btn-icon">📖</text>
      <text class="menu-btn-text">关 于 游 戏</text>
    </view>
  </view>

  <!-- ===== 学科选择面板 ===== -->
  <view class="overlay" wx:if="{{showDisciplineSelect}}" catchtouchmove="preventTouchMove">
    <view class="panel pixel-panel">
      <text class="panel-title">🔬 选择你的学科</text>
      <text class="panel-subtitle">不同学科对应不同的初始牌组</text>

      <scroll-view class="panel-list" scroll-y style="max-height: 55vh;">
        <view
          wx:for="{{disciplines}}"
          wx:key="id"
          class="panel-card pixel-panel {{selectedDiscipline === item.id ? 'card-selected' : ''}} {{item.unlocked ? '' : 'card-locked'}}"
          data-discipline-id="{{item.id}}"
          bindtap="onSelectDiscipline"
        >
          <view class="card-header">
            <text class="card-icon">{{item.icon}}</text>
            <text class="card-name">{{item.name}}</text>
            <text class="lock-icon" wx:if="{{!item.unlocked}}">🔒</text>
          </view>
          <view class="card-desc">
            <text>{{item.description}}</text>
          </view>
        </view>
      </scroll-view>

      <view class="panel-footer">
        <view class="pixel-btn pixel-btn-small" bindtap="onCancelDiscipline">返回</view>
        <text class="panel-tip">选择学科后选择难度</text>
      </view>
    </view>
  </view>

  <!-- ===== 难度选择面板 ===== -->
  <view class="overlay" wx:if="{{showDifficultySelect}}" catchtouchmove="preventTouchMove">
    <view class="panel pixel-panel">
      <text class="panel-title">🎯 选择难度</text>
      <text class="panel-subtitle">高难度 = 高回报（更多学术声望）</text>

      <scroll-view class="panel-list" scroll-y style="max-height: 55vh;">
        <view
          wx:for="{{difficulties}}"
          wx:key="id"
          class="panel-card pixel-panel {{selectedDifficulty === item.id ? 'card-selected' : ''}} {{item.unlocked ? '' : 'card-locked'}}"
          data-difficulty-id="{{item.id}}"
          bindtap="onSelectDifficulty"
        >
          <view class="card-header">
            <text class="card-name">{{item.name}}</text>
            <text class="lock-icon" wx:if="{{!item.unlocked}}">🔒 (需 {{item.requirement.ap}} AP)</text>
          </view>
          <view class="card-desc">
            <text>{{item.description}}</text>
          </view>
        </view>
      </scroll-view>

      <view class="panel-footer">
        <view class="pixel-btn pixel-btn-small" bindtap="onCancelDifficulty">返回选学科</view>
        <text class="panel-tip">点击难度开始 Run</text>
      </view>
    </view>
  </view>

  <!-- ===== 关于面板 ===== -->
  <view class="about-panel pixel-panel" wx:if="{{showAbout}}">
    <text class="about-title">📖 关于小丑牌-学术版</text>
    <view class="about-content">
      <text class="about-text">一个博士学术主题的 Roguelike 卡牌构建游戏。</text>
      <text class="about-text">🎯 每局(Run)：选择学科牌组 → 闯过12关 → 最终答辩</text>
      <text class="about-text">📝 研究方法卡：实验/写作/数据分析/社交/教学</text>
      <text class="about-text">🧠 技能卡：类似小丑牌，提供被动加成</text>
      <text class="about-text">🏪 商店：每关后用经费购买技能卡和机遇卡</text>
      <text class="about-text">⭐ 学术声望：完成Run积累，解锁新内容</text>
      <text class="about-text mt-16 text-dim">v2.0.0 · 由博士生存指南进化而来</text>
    </view>
    <view class="pixel-btn pixel-btn-small" bindtap="onToggleAbout" style="margin-top: 16rpx;">关闭</view>
  </view>

  <view class="footer">
    <text class="footer-text">v2.0.0 · Academic Roguelike</text>
  </view>

</view>
