/**
 * 学术 Roguelike —— 结局页样式
 */

.ending-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: #1a1a2e;
  color: #eeeeb8;
}

.ending-victory { background: linear-gradient(180deg, #0a1628 0%, #1a1a2e 50%); }
.ending-failure { background: linear-gradient(180deg, #280a0a 0%, #1a1a2e 50%); }

/* 主视觉 */
.ending-hero { text-align: center; margin-bottom: 40rpx; }
.ending-emoji { font-size: 100rpx; display: block; margin-bottom: 20rpx; animation: float 2s ease-in-out infinite; }
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12rpx)} }
.ending-title { font-size: 44rpx; font-weight: bold; display: block; margin-bottom: 12rpx; }
.ending-subtitle { font-size: 24rpx; color: #888; }

/* 统计 */
.ending-stats { width: 100%; max-width: 500rpx; padding: 28rpx; margin-bottom: 20rpx; }
.stats-title { font-size: 26rpx; font-weight: bold; color: #f0a500; display: block; margin-bottom: 16rpx; }

.stats-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.stat-item {
  width: calc(50% - 6rpx); display: flex; flex-direction: column;
  padding: 12rpx; background: rgba(255,255,255,0.05);
}
.stat-label { font-size: 20rpx; color: #888; }
.stat-value { font-size: 28rpx; font-weight: bold; color: #eeeeb8; margin-top: 4rpx; }

/* AP 结算 */
.ending-ap { width: 100%; max-width: 500rpx; padding: 28rpx; margin-bottom: 24rpx; border-color: #f0a500; }
.ap-title { font-size: 26rpx; font-weight: bold; color: #f0a500; display: block; margin-bottom: 12rpx; }
.ap-row { display: flex; justify-content: space-between; align-items: center; }
.ap-label { font-size: 24rpx; color: #888; }
.ap-value { font-size: 32rpx; font-weight: bold; color: #f0a500; }

/* 操作 */
.ending-actions { width: 100%; max-width: 500rpx; display: flex; flex-direction: column; gap: 16rpx; margin-top: 20rpx; }
