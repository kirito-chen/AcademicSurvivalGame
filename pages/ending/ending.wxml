<!-- 学术 Roguelike —— 结局页 -->
<view class="ending-page {{typeClass}}">

  <!-- 结局主视觉 -->
  <view class="ending-hero">
    <text class="ending-emoji">{{typeIcon}}</text>
    <text class="ending-title pixel-text-glow">
      {{won ? '恭喜毕业！' : '科研之路中断'}}
    </text>
    <view class="ending-subtitle">
      <text>{{won ? '你成功通过了最终答辩！' : '这次博士之旅结束了……'}}</text>
    </view>
  </view>

  <!-- Run 统计 -->
  <view class="ending-stats pixel-panel">
    <text class="stats-title">📊 本轮 Run 统计</text>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-label">总学术产出</text>
        <text class="stat-value">{{totalScore}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">通过学期</text>
        <text class="stat-value">{{anteReached}}/4</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">打出手牌</text>
        <text class="stat-value">{{totalCardsPlayed}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">通过关卡</text>
        <text class="stat-value">{{totalRoundsCleared}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">最高单次产出</text>
        <text class="stat-value">{{highestSingleScore}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">学科</text>
        <text class="stat-value">{{discipline}}</text>
      </view>
    </view>
  </view>

  <!-- 学术声望结算 -->
  <view class="ending-ap pixel-panel">
    <text class="ap-title">⭐ 学术声望结算</text>
    <view class="ap-row">
      <text class="ap-label">本轮获得</text>
      <text class="ap-value">+{{apGained}} AP</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="ending-actions">
    <view class="pixel-btn pixel-btn-large" bindtap="onPlayAgain">
      🔄 再来一局 (相同配置)
    </view>
    <view class="pixel-btn pixel-btn-large mt-24" bindtap="onBackHome">
      🏠 返回首页
    </view>
  </view>

</view>
