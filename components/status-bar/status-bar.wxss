.status-bar {
  padding: 12rpx 16rpx;
  flex-shrink: 0;
}

.status-header {
  margin-bottom: 8rpx;
  padding-bottom: 6rpx;
  border-bottom: 1rpx dashed var(--color-border-dim);
}

.day-number {
  font-family: monospace;
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text);
  -webkit-font-smoothing: none;
}

.day-phase {
  font-family: monospace;
  font-size: 22rpx;
  color: var(--color-warning);
  -webkit-font-smoothing: none;
  margin-left: 8rpx;
}

.talent-badge {
  font-family: monospace;
  font-size: 20rpx;
  color: var(--color-success);
  -webkit-font-smoothing: none;
  margin-left: 8rpx;
  padding: 1rpx 8rpx;
  border: 1rpx solid var(--color-success);
}

.year-text {
  font-family: monospace;
  font-size: 20rpx;
  color: var(--color-text-dim);
  -webkit-font-smoothing: none;
  padding: 2rpx 8rpx;
  border: 1rpx solid var(--color-border-dim);
  white-space: nowrap;
}

/* 2×2 资源网格 */
.resources-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx 12rpx;
}

.resources-grid > resource-bar {
  flex: 0 0 calc(50% - 6rpx);
  max-width: calc(50% - 6rpx);
}

/* 次要资源单行 */
.secondary-row {
  margin-top: 6rpx;
  padding-top: 4rpx;
  border-top: 1rpx dashed var(--color-border-dim);
  gap: 24rpx;
  justify-content: center;
}

.sec-item {
  font-family: monospace;
  font-size: 20rpx;
  color: var(--color-text-dim);
  -webkit-font-smoothing: none;
}
