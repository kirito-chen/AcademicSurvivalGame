/**
 * 小丑牌-学术版 —— 通用卡牌组件样式
 */

.game-card {
  position: relative; display: inline-flex; flex-direction: column; align-items: center;
  border-radius: 6rpx; cursor: pointer;
  transition: all 0.15s ease; overflow: hidden;
}

/* === 研究方法卡：扑克牌风 === */
.game-card.card-research {
  width: 110rpx; height: 160rpx;
  background: #fefefe; color: #1a1a2e;
  border: 3rpx solid var(--card-color, #aaa);
  box-shadow: 3rpx 3rpx 0 rgba(0,0,0,0.4);
  padding: 0;
}

.game-card.card-research.compact {
  width: 100rpx; height: 145rpx;
}

/* 角落 rank + suit */
.card-corner { position: absolute; display: flex; flex-direction: column; align-items: center; line-height: 1; }
.top-left { top: 4rpx; left: 6rpx; }
.bottom-right { bottom: 4rpx; right: 6rpx; transform: rotate(180deg); }
.corner-rank { font-size: 22rpx; font-weight: bold; color: #1a1a2e; }
.corner-suit { font-size: 18rpx; }

/* 中央花色 */
.card-center { flex: 1; display: flex; align-items: center; justify-content: center; }
.center-suit { font-size: 56rpx; line-height: 1; }
.compact .center-suit { font-size: 44rpx; }

/* 角落花色 */
.corner-suit-sym { font-size: 20rpx; }

/* 底部信息 */
.card-name-mini { font-size: 16rpx; color: #555; text-align: center; padding: 0 4rpx 2rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 100%; }
.card-cost-mini { font-size: 16rpx; color: #e94560; font-weight: bold; padding-bottom: 2rpx; }

/* === 技能卡 === */
.game-card.card-skill {
  min-width: 110rpx; max-width: 150rpx; padding: 8rpx 10rpx;
  background: #16213e; border: 4rpx solid var(--card-color, #aaa);
  box-shadow: 4rpx 4rpx 0 var(--card-color, #aaa);
}
.card-icon { font-size: 38rpx; margin-bottom: 4rpx; }
.card-info { display: flex; flex-direction: column; align-items: center; width: 100%; }
.card-name { font-size: 20rpx; color: #eeeeb8; font-weight: bold; text-align: center; max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 4rpx; }
.card-rarity { font-size: 18rpx; font-weight: bold; margin: 2rpx 0; }
.card-desc { font-size: 17rpx; color: #888; text-align: center; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.card-cost { font-size: 18rpx; color: #f0a500; font-weight: bold; }

/* === 机遇卡 === */
.game-card.card-consumable {
  min-width: 120rpx; max-width: 170rpx; padding: 10rpx 14rpx;
  background: #16213e; border: 4rpx solid #4ecdc4;
  box-shadow: 4rpx 4rpx 0 #4ecdc4;
}

/* === 状态 === */
.game-card.selected { transform: translateY(-8rpx); box-shadow: 3rpx 8rpx 0 rgba(0,0,0,0.5); border-color: #fff; }
.game-card.selected::after { content: ''; position: absolute; inset: -6rpx; border: 2rpx dashed rgba(255,255,255,0.4); pointer-events: none; border-radius: 8rpx; }
.game-card.disabled { opacity: 0.4; filter: grayscale(50%); }
.game-card:active { transform: scale(0.95); }
.game-card.selected:active { transform: translateY(-8rpx) scale(0.95); }

.select-check {
  position: absolute; top: -6rpx; left: -6rpx;
  background: #2ecc71; color: #fff; font-size: 18rpx; font-weight: bold;
  width: 28rpx; height: 28rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  border: 2rpx solid #1a1a2e; z-index: 5;
}
