/**
 * 学术 Roguelike —— 通用卡牌组件样式
 */

.game-card {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  border: 4rpx solid var(--card-color, #aaa);
  background: #16213e;
  box-shadow: 4rpx 4rpx 0 var(--card-color, #aaa);
  transition: all 0.15s ease;
  min-width: 140rpx;
  max-width: 200rpx;
  cursor: pointer;
}

/* 研究方法卡 */
.game-card.card-research {
  min-width: 120rpx;
  max-width: 160rpx;
  padding: 8rpx 12rpx;
}

/* 技能卡 */
.game-card.card-skill {
  min-width: 100rpx;
  max-width: 140rpx;
  padding: 8rpx 10rpx;
  border-radius: 4rpx;
}

/* 机遇卡 */
.game-card.card-consumable {
  min-width: 130rpx;
  max-width: 180rpx;
}

/* 紧凑模式(手牌区) */
.game-card.compact {
  min-width: 100rpx;
  max-width: 130rpx;
  padding: 6rpx 10rpx;
}

/* 选中状态 */
.game-card.selected {
  transform: translateY(-16rpx);
  box-shadow: 4rpx 8rpx 0 var(--card-color, #aaa);
  border-color: #fff;
}

.game-card.selected::after {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.4);
  pointer-events: none;
}

/* 禁用状态 */
.game-card.disabled {
  opacity: 0.4;
  filter: grayscale(50%);
}

/* 按下状态 */
.game-card:active {
  transform: translateY(2rpx) scale(0.97);
  box-shadow: 2rpx 2rpx 0 var(--card-color, #aaa);
}

.game-card.selected:active {
  transform: translateY(-12rpx) scale(0.97);
}

.card-icon {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.card-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.card-name {
  font-size: 20rpx;
  color: #eeeeb8;
  font-weight: bold;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
  margin-bottom: 4rpx;
}

.card-stats {
  display: flex;
  gap: 8rpx;
  justify-content: center;
}

.stat {
  font-size: 18rpx;
  padding: 2rpx 6rpx;
  font-weight: bold;
}

.stat.production {
  color: #00b4d8;
}

.stat.energy-cost {
  color: #e94560;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
  justify-content: center;
  margin-top: 4rpx;
}

.tag {
  font-size: 16rpx;
  color: #666;
  background: rgba(255, 255, 255, 0.1);
  padding: 1rpx 6rpx;
}

.card-rarity {
  font-size: 18rpx;
  font-weight: bold;
  margin: 2rpx 0;
}

.card-desc {
  font-size: 18rpx;
  color: #888;
  text-align: center;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-cost {
  font-size: 18rpx;
  color: #f0a500;
  font-weight: bold;
}

.card-icon-only {
  font-size: 48rpx;
}

/* 升级标记 */
.upgrade-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #f0a500;
  color: #1a1a2e;
  font-size: 18rpx;
  font-weight: bold;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #1a1a2e;
}

/* 选中勾 */
.select-check {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  background: #2ecc71;
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #1a1a2e;
}
