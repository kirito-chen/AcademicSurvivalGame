<!-- 小丑牌-学术版 —— 通用卡牌组件 -->
<view
  class="game-card card-{{cardType}} {{selected ? 'selected' : ''}} {{disabled ? 'disabled' : ''}} {{compact ? 'compact' : ''}}"
  style="--card-color: {{cardType === 'research' ? (suitColors[card.suit] || '#aaa') : (cardType === 'skill' ? (rarityColors[card.rarity] || '#aaa') : '#4ecdc4')}}"
  bindtap="onTap"
  bindlongpress="onLongPress"
>

  <!-- 研究方法卡：扑克牌风格 -->
  <block wx:if="{{cardType === 'research'}}">
    <view class="card-corner top-left">
      <text class="corner-rank" style="color: {{suitColors[card.suit] || '#1a1a2e'}}">{{card.rank || '?'}}</text>
      <text class="corner-suit-sym" style="color: {{suitColors[card.suit] || '#1a1a2e'}}">{{suitSymbols[card.suit] || '?'}}</text>
    </view>
    <view class="card-center">
      <text class="center-suit" style="color: {{suitColors[card.suit] || '#1a1a2e'}}">{{suitSymbols[card.suit] || '?'}}</text>
    </view>
    <view class="card-corner bottom-right">
      <text class="corner-rank" style="color: {{suitColors[card.suit] || '#1a1a2e'}}">{{card.rank || '?'}}</text>
      <text class="corner-suit-sym" style="color: {{suitColors[card.suit] || '#1a1a2e'}}">{{suitSymbols[card.suit] || '?'}}</text>
    </view>
    <view class="card-name-mini" wx:if="{{!compact}}">{{card.name}}</view>
    <view class="card-cost-mini">{{card.energyCost || 0}}⚡</view>
  </block>

  <!-- 技能卡 -->
  <block wx:if="{{cardType === 'skill'}}">
    <view class="card-icon">{{card.icon || '🧠'}}</view>
    <view class="card-info" wx:if="{{showDetail}}">
      <text class="card-name">{{card.name || '?'}}</text>
      <view class="card-rarity" style="color: {{rarityColors[card.rarity] || '#aaa'}}">{{rarityNames[card.rarity] || '?'}}</view>
      <view class="card-desc" wx:if="{{!compact}}">{{card.description || ''}}</view>
    </view>
  </block>

  <!-- 机遇卡 -->
  <block wx:if="{{cardType === 'consumable'}}">
    <view class="card-icon">{{card.icon || '🎲'}}</view>
    <view class="card-info" wx:if="{{showDetail}}">
      <text class="card-name">{{card.name || '?'}}</text>
      <view class="card-cost">价格: {{card.price || card.cost || '?'}}</view>
      <view class="card-desc" wx:if="{{!compact}}">{{card.description || ''}}</view>
    </view>
  </block>

  <!-- 技能卡/机遇卡显示选中勾，手牌不显示 -->
  <view class="select-check" wx:if="{{selected && cardType !== 'research'}}">✓</view>
</view>
