<view
  class="decision-card pixel-panel {{available ? '' : 'decision-disabled'}}"
  bindtap="onTap"
  bindlongpress="onLongPress"
>
  <text class="decision-icon">{{decision.icon}}</text>
  <text class="decision-name">{{decision.name}}</text>
  <view class="decision-badge badge-category" wx:if="{{available}}">
    <text class="badge-text">{{decision.category === 'academic' ? '学术' : decision.category === 'rest' ? '休息' : '副业'}}</text>
  </view>
  <view class="decision-badge" wx:else>
    <text class="badge-text">不可用</text>
  </view>
</view>
